module EscrowAgent where

import Daml.Script

import qualified Escrow.Base
import qualified PartialRelease

-- | Defines the role and capabilities of the neutral escrow agent for a specific
-- | escrow agreement. This contract is created by the agent upon accepting their
-- | role in an escrow transaction. It provides choices for the agent to mediate
-- | the release, refund, or partial release of funds, especially in disputed scenarios.
template EscrowAgent
  with
    agent: Party
      -- ^ The neutral escrow agent party.

    buyer: Party
      -- ^ The party purchasing goods/services.

    seller: Party
      -- ^ The party selling goods/services.

    escrowCid: ContractId Escrow.Base.Escrow
      -- ^ The associated escrow contract holding the funds.
  where
    signatory agent
    observer buyer, seller

    key (agent, escrowCid) : (Party, ContractId Escrow.Base.Escrow)
    maintainer key._1

    -- | Choice for the agent to unilaterally decide to release the full escrowed
    -- | amount to the seller. This is typically used to resolve a dispute after
    -- | off-ledger verification of fulfillment has been provided to the agent.
    choice ForceReleaseFunds : ()
      controller agent
      do
        -- Exercise the corresponding choice on the main escrow contract to
        -- release the funds and archive the escrow. This action is final.
        exercise escrowCid Escrow.Base.AgentRelease
        return ()

    -- | Choice for the agent to unilaterally decide to refund the full escrowed
    -- | amount to the buyer. This is used if the seller fails to deliver or
    -- | to resolve a dispute in the buyer's favor.
    choice ForceRefundFunds : ()
      controller agent
      do
        -- Exercise the corresponding choice on the main escrow contract to
        -- refund the funds and archive the escrow. This action is final.
        exercise escrowCid Escrow.Base.AgentRefund
        return ()

    -- | Allows the agent to approve and execute a partial release of funds.
    -- | This is used when the buyer and seller have agreed to a milestone payment
    -- | or partial delivery. The agent's approval provides a neutral third-party
    -- | sign-off on the transaction, executing the partial payment from the
    -- | escrowed funds.
    choice ApprovePartialRelease : ContractId Escrow.Base.Escrow
      with
        releaseRequestCid : ContractId PartialRelease.Request
          -- ^ The `PartialRelease.Request` contract to approve.
      controller agent
      do
        -- Fetch the request to verify its details match the escrow context.
        -- This ensures the agent is not approving a request for a different escrow.
        releaseRequest <- fetch releaseRequestCid
        assertMsg "Partial release request does not belong to this escrow agreement."
          (releaseRequest.escrowCid == escrowCid)

        -- The agent is the final approver, exercising the settlement choice on
        -- the main escrow contract. This atomically processes the payment and
        -- archives the release request.
        exercise escrowCid Escrow.Base.SettlePartial with
          releaseRequestCid = releaseRequestCid
          amountToRelease = releaseRequest.amount