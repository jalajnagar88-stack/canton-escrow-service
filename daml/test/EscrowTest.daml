module EscrowTest where

import Daml.Script
import DA.Assert
import DA.Date as Date
import DA.Time (time)
import Escrow
import Arbitration
import PartialRelease

-- === Test Setup ===

data Parties = Parties
  { buyer : Party
  , seller : Party
  , agent : Party
  , arbitrator : Party
  }

setupParties : Script Parties
setupParties = do
  buyer <- allocatePartyWithHint "Buyer" (PartyIdHint "buyer")
  seller <- allocatePartyWithHint "Seller" (PartyIdHint "seller")
  agent <- allocatePartyWithHint "EscrowAgent" (PartyIdHint "escrow-agent")
  arbitrator <- allocatePartyWithHint "Arbitrator" (PartyIdHint "arbitrator")
  return Parties with ..

-- === Test Scenarios ===

testHappyPathRelease : Script ()
testHappyPathRelease = script do
  p <- setupParties

  -- 1. Agent creates the escrow agreement, signed by all three parties.
  let now = time (Date.date 2024 Date.Jan 1) 0 0 0
  let escrowAmount = 1000.0
  let agreement = Agreement with
        buyer = p.buyer
        seller = p.seller
        agent = p.agent
        arbitrator = p.arbitrator
        amount = escrowAmount
        description = "Vintage Watch"
        createdAt = now
        buyerConfirmed = False
        sellerConfirmed = False
        buyerRequestedRefund = False
        sellerApprovedRefund = False

  agreementCid <- submit p.agent do
    createCmd agreement

  -- 2. Buyer confirms they have received the goods.
  agreementCid_BuyerConfirmed <- submit p.buyer do
    exerciseCmd agreementCid ConfirmDelivery

  -- Assert that agent cannot release yet, as seller has not confirmed.
  submitMustFail p.agent do
    exerciseCmd agreementCid_BuyerConfirmed ReleaseFunds

  -- 3. Seller confirms they are satisfied with the buyer's confirmation.
  agreementCid_SellerConfirmed <- submit p.seller do
    exerciseCmd agreementCid_BuyerConfirmed ConfirmReceipt

  -- 4. Agent releases the funds to the seller, archiving the agreement.
  submit p.agent do
    exerciseCmd agreementCid_SellerConfirmed ReleaseFunds

  -- 5. Verify the agreement is archived.
  agreements <- query @Agreement p.agent
  assert (null agreements)
  return ()


testAgreedRefund : Script ()
testAgreedRefund = script do
  p <- setupParties

  -- 1. Agent creates the escrow agreement.
  let now = time (Date.date 2024 Date.Feb 15) 0 0 0
  let escrowAmount = 500.0
  let agreement = Agreement with
        buyer = p.buyer
        seller = p.seller
        agent = p.agent
        arbitrator = p.arbitrator
        amount = escrowAmount
        description = "Custom Software Module"
        createdAt = now
        buyerConfirmed = False
        sellerConfirmed = False
        buyerRequestedRefund = False
        sellerApprovedRefund = False

  agreementCid <- submit p.agent do
    createCmd agreement

  -- 2. Buyer requests a refund (e.g., they changed their mind).
  agreementCid_RefundRequested <- submit p.buyer do
    exerciseCmd agreementCid RequestRefund

  -- Assert that agent cannot refund yet, as seller has not approved.
  submitMustFail p.agent do
    exerciseCmd agreementCid_RefundRequested RefundFunds

  -- 3. Seller agrees to the refund.
  agreementCid_RefundApproved <- submit p.seller do
    exerciseCmd agreementCid_RefundRequested ApproveRefund

  -- 4. Agent processes the refund to the buyer.
  submit p.agent do
    exerciseCmd agreementCid_RefundApproved RefundFunds

  -- 5. Verify the agreement is archived.
  agreements <- query @Agreement p.agent
  assert (null agreements)
  return ()

testDisputeAndArbitration : Script ()
testDisputeAndArbitration = script do
  p <- setupParties

  -- 1. Agent creates the escrow agreement.
  let now = time (Date.date 2024 Mar 10) 0 0 0
  let escrowAmount = 2500.0
  let agreement = Agreement with
        buyer = p.buyer
        seller = p.seller
        agent = p.agent
        arbitrator = p.arbitrator
        amount = escrowAmount
        description = "Graphic Design Services"
        createdAt = now
        buyerConfirmed = False
        sellerConfirmed = False
        buyerRequestedRefund = False
        sellerApprovedRefund = False

  agreementCid <- submit p.agent do
    createCmd agreement

  -- 2. Buyer raises a dispute, claiming the work is not as described.
  let disputeReason = "The delivered design assets do not meet the specifications outlined in the brief."
  disputeCid <- submit p.buyer do
    exerciseCmd agreementCid (RaiseDispute with reason = disputeReason)

  -- 3. Agent reviews the dispute and escalates it to the designated arbitrator.
  let escalationNotes = "Initial mediation failed. Buyer and seller cannot agree. Escalating for binding arbitration."
  caseCid <- submit p.agent do
    exerciseCmd disputeCid (EscalateToArbitration with notes = escalationNotes)

  -- 4. Arbitrator reviews the case and makes a ruling.
  -- In this scenario, the arbitrator finds fault on both sides and decides on a partial release.
  -- Seller gets 60% for work done, Buyer gets 40% back.
  let buyerPayout = 0.4 * escrowAmount
  let sellerPayout = 0.6 * escrowAmount
  let partialRelease = Split with buyerAmount = buyerPayout, sellerAmount = sellerPayout
  let rulingReason = "Seller provided a significant portion of the agreed work but failed on key specifications. Buyer was not clear in their revision requests. A 60/40 split is deemed equitable."

  assertMsg "Payouts must sum to total escrow amount" (buyerPayout + sellerPayout == escrowAmount)

  rulingCid <- submit p.arbitrator do
    exerciseCmd caseCid (Rule with ruling = partialRelease, reason = rulingReason)

  -- 5. Agent executes the ruling from the arbitrator.
  submit p.agent do
    exerciseCmd rulingCid ExecuteRuling

  -- 6. Verify all contracts (Agreement, Dispute, Case, Ruling) are archived.
  agreements <- query @Agreement p.agent
  assert (null agreements)
  disputes <- query @Dispute p.agent
  assert (null disputes)
  cases <- query @Case p.agent
  assert (null cases)
  rulings <- query @Ruling p.agent
  assert (null rulings)

  return ()

testDisputeSellerInitiated : Script ()
testDisputeSellerInitiated = script do
  p <- setupParties

  -- 1. Agent creates the escrow agreement.
  let now = time (Date.date 2024 Apr 1) 0 0 0
  let escrowAmount = 750.0
  let agreement = Agreement with
        buyer = p.buyer
        seller = p.seller
        agent = p.agent
        arbitrator = p.arbitrator
        amount = escrowAmount
        description = "Handmade Furniture"
        createdAt = now
        buyerConfirmed = False
        sellerConfirmed = False
        buyerRequestedRefund = False
        sellerApprovedRefund = False

  agreementCid <- submit p.agent do
    createCmd agreement

  -- 2. Seller claims they have delivered but buyer is unresponsive and won't confirm.
  let disputeReason = "Goods were delivered and signed for on March 28th, but the buyer has not confirmed receipt on the platform and is not responding to messages."
  disputeCid <- submit p.seller do
    exerciseCmd agreementCid (RaiseDispute with reason = disputeReason)

  -- 3. Agent escalates to arbitration.
  let escalationNotes = "Seller provided proof of delivery. Buyer is unresponsive."
  caseCid <- submit p.agent do
    exerciseCmd disputeCid (EscalateToArbitration with notes = escalationNotes)

  -- 4. Arbitrator reviews evidence and rules in favor of the seller.
  let partialRelease = Split with buyerAmount = 0.0, sellerAmount = escrowAmount
  let rulingReason = "Seller has provided a valid proof of delivery document signed by the buyer. Buyer has not responded to inquiries from the agent or arbitrator. Full release to seller is warranted."

  rulingCid <- submit p.arbitrator do
    exerciseCmd caseCid (Rule with ruling = partialRelease, reason = rulingReason)

  -- 5. Agent executes the full release to the seller.
  submit p.agent do
    exerciseCmd rulingCid ExecuteRuling

  -- 6. Verify contracts are archived.
  agreements <- query @Agreement p.agent
  assert (null agreements)

  return ()


-- === Test Suite ===

escrowTests : Script ()
escrowTests = do
  test "HappyPathRelease" "Full release after both parties confirm" testHappyPathRelease
  test "AgreedRefund" "Full refund after both parties agree" testAgreedRefund
  test "DisputeAndArbitration" "A disputed transaction is settled via partial release by an arbitrator" testDisputeAndArbitration
  test "DisputeSellerInitiated" "Seller initiates a dispute and wins arbitration" testDisputeSellerInitiated